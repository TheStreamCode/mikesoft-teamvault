# EditorConfig: https://editorconfig.org
# Keeps formatting consistent across editors for this repository.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{js,json,yml,yaml}]
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[*.txt]
trim_trailing_whitespace = false

# Normalize line endings: text files use LF in the repository.
* text=auto eol=lf

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.mo binary
*.zip binary

# Keep useful diffs for these
*.php diff=php
*.md diff=markdown

# Exclude repository-only material from `git archive` exports
.github export-ignore
.wordpress-org export-ignore
.worktrees export-ignore
docs export-ignore
tests export-ignore
tools export-ignore
screenshots export-ignore
.editorconfig export-ignore
.gitattributes export-ignore
.gitignore export-ignore
AGENTS.md export-ignore
CODE_OF_CONDUCT.md export-ignore
CONTRIBUTING.md export-ignore
README.md export-ignore
README.it.md export-ignore
README.fr.md export-ignore
README.es.md export-ignore
README.de.md export-ignore
COPYRIGHT.md export-ignore
SECURITY.md export-ignore
composer.json export-ignore
composer.lock export-ignore
